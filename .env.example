# ─────────────────────────────────────────────────────────────────
# Freelance Proposal Analyzer — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────

# LLM Model Configuration (via LiteLLM)
# Cheap model: used for extraction tasks (Job Intelligence, Rate Intelligence)
# Strong model: used for reasoning tasks (Proposal Analyst, Win Strategy)
CHEAP_MODEL_NAME=anthropic/claude-haiku-4-5-20251001
STRONG_MODEL_NAME=anthropic/claude-sonnet-4-5-20250929

# Anthropic API Key
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS — set to your Lovable app URL
# Example: https://your-app-name.lovable.app
# In production this is set in Railway dashboard, NOT here
ALLOWED_ORIGIN=http://localhost:3000
